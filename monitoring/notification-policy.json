{
  "receiver": "dooray-alerts",
  "group_by": [
    "grafana_folder",
    "alertname"
  ],
  "routes": [
    {
      "receiver": "dooray-alerts",
      "matchers": [
        "severity=\"critical\""
      ],
      "group_wait": "30s",
      "group_interval": "5m",
      "repeat_interval": "1h"
    },
    {
      "receiver": "dooray-alerts",
      "matchers": [
        "severity=\"warning\""
      ],
      "group_wait": "1m",
      "group_interval": "10m",
      "repeat_interval": "4h"
    }
  ]
}